{
  "name": "@allpush/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env src/index.ts",
    "build": "node scripts/generate-api-docs.mjs && npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/index.js",
    "prisma:generate": "cd ../.. && prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:push": "cd ../.. && prisma db push --schema=apps/api/prisma/schema.prisma",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.8.2",
    "all-pusher-api": "^1.1.10",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.3.3",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "prisma": "^6.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
