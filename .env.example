# 数据库路径（SQLite）
DATABASE_URL="file:./prisma/dev.db"

# JWT 签名密钥（生产环境务必修改为随机字符串）
JWT_SECRET="change-me-to-a-random-secret"

# 初始管理员账号（首次启动时自动创建）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# 日志保留天数（默认 30）
LOG_RETENTION_DEFAULT_DAYS="30"

# 服务端口（可选，默认 3000）
# PORT=3000

# 服务监听地址（可选，默认 0.0.0.0）
# HOST=0.0.0.0

# CORS 允许的来源，逗号分隔（可选）
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 认证接口限流 - 每分钟最大请求数（可选，默认 10）
# AUTH_RATE_LIMIT_MAX=10

# 推送接口限流 - 每分钟最大请求数（可选，默认 60）
# PUSH_RATE_LIMIT_MAX=60

# 推送失败明细条数上限（可选，默认 20，最大 100）
# PUSH_FAILED_DETAIL_LIMIT=20

# 推送失败消息最大长度（可选，默认 300）
# PUSH_FAILED_MESSAGE_MAX_LEN=300
